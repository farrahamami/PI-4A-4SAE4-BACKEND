pipeline {
    agent any

    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }

    environment {
        SERVICE_NAME      = 'publication-service'
        DOCKER_NAMESPACE  = 'farahchbeb'
        IMAGE_NAME        = "${DOCKER_NAMESPACE}/${SERVICE_NAME}"
        IMAGE_TAG         = "${env.BUILD_NUMBER}"
        SONAR_PROJECT     = 'publication-service'
        APP_PORT          = '8082'
        ZAP_CONTAINER     = 'zap-target-publication'
    }

    options {
        timeout(time: 40, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('🔨 Compile') {
            steps {
                dir('publication-service') {
                    sh 'mvn clean compile -B'
                }
            }
        }

        stage('🧪 Tests + Coverage JaCoCo') {
            steps {
                dir('publication-service') {
                    sh 'mvn test -B'
                }
            }
            post {
                always {
                    junit testResults: 'publication-service/target/surefire-reports/*.xml',
                          allowEmptyResults: true
                    jacoco execPattern: 'publication-service/target/jacoco.exec',
                           classPattern: 'publication-service/target/classes',
                           sourcePattern: 'publication-service/src/main/java',
                           exclusionPattern: '**/dto/**,**/entities/**,**/config/**,**/*Application.class'
                }
            }
        }

        stage('📦 Package JAR') {
            steps {
                dir('publication-service') {
                    sh 'mvn package -DskipTests -B'
                }
                archiveArtifacts artifacts: 'publication-service/target/*.jar', fingerprint: true
            }
        }

        stage('🔍 SonarQube Analysis') {
            steps {
                dir('publication-service') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn sonar:sonar \
                              -Dsonar.projectKey=${SONAR_PROJECT} \
                              -Dsonar.projectName=${SONAR_PROJECT} \
                              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        '''
                    }
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('publication-service') {
                    sh 'docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest .'
                }
            }
        }

        stage('🔒 OWASP ZAP Security Scan') {
            steps {
                script {
                    sh "docker stop ${ZAP_CONTAINER} 2>/dev/null || true && docker rm ${ZAP_CONTAINER} 2>/dev/null || true"

                    // Démarrer le service avec --network host pour que ZAP puisse l'atteindre via localhost
                    sh """
                        docker run -d --name ${ZAP_CONTAINER} \
                          --network host \
                          -e SERVER_PORT=${APP_PORT} \
                          -e GRAYLOG_HOST=localhost \
                          ${IMAGE_NAME}:${IMAGE_TAG}
                    """

                    // Attendre que le service soit vraiment UP (max 90s)
                    sh """
                        echo "⏳ Attente que le service soit disponible sur le port ${APP_PORT}..."
                        for i in \$(seq 1 18); do
                            if curl -sf http://localhost:${APP_PORT}/actuator/health > /dev/null 2>&1; then
                                echo "✅ Service UP après \$((i * 5)) secondes"
                                break
                            fi
                            echo "  ... tentative \$i/18 (5s)"
                            sleep 5
                        done
                        # Vérification finale
                        curl -sf http://localhost:${APP_PORT}/actuator/health || \
                        curl -sf http://localhost:${APP_PORT} || \
                        echo "⚠️ Service peut-être pas encore prêt, ZAP va tenter quand même"
                    """

                    sh 'mkdir -p zap-reports && chmod 777 zap-reports'

                    // --user root : évite le PermissionError sur /zap/wrk/zap.yaml
                    // --network host : ZAP accède à localhost:8082 directement
                    sh """
                        docker run --rm --network host \
                          --user root \
                          -v \$(pwd)/zap-reports:/zap/wrk/:rw \
                          zaproxy/zap-stable \
                          zap-baseline.py \
                          -t http://localhost:${APP_PORT} \
                          -r zap-report.html \
                          -x zap-report.xml \
                          -I
                    """
                }
            }
            post {
                always {
                    sh "docker stop ${ZAP_CONTAINER} 2>/dev/null || true && docker rm ${ZAP_CONTAINER} 2>/dev/null || true"
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'zap-reports',
                        reportFiles: 'zap-report.html',
                        reportName: "OWASP ZAP Report - ${SERVICE_NAME}"
                    ])
                    archiveArtifacts artifacts: 'zap-reports/zap-report.xml', allowEmptyArchive: true
                }
            }
        }

        stage('📤 Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                        docker logout
                    '''
                }
            }
        }

        stage('💾 Save build info for CD') {
            steps {
                writeFile file: 'last-build.txt', text: "${IMAGE_TAG}"
                archiveArtifacts artifacts: 'last-build.txt'
            }
        }
    }

    post {
        success {
            echo "✅ CI OK : image ${IMAGE_NAME}:${IMAGE_TAG} poussée sur DockerHub."
        }
        failure {
            echo "❌ CI échoué."
            sh "docker stop ${ZAP_CONTAINER} 2>/dev/null || true && docker rm ${ZAP_CONTAINER} 2>/dev/null || true"
        }
        always {
            cleanWs()
        }
    }
}