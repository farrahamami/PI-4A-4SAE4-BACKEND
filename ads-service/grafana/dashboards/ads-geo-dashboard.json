      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
          "queryType": "sql",
          "rawSql": "SELECT type, count(*) as total FROM ads_analytics.ad_events WHERE event_time >= now() - INTERVAL 24 HOUR GROUP BY type ORDER BY total DESC",
          "refId": "A",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
