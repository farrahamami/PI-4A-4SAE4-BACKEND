    {
      "id": 4,
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(event_time) as time, type, count(*) as events FROM ads_analytics.ad_events WHERE event_time >= now() - INTERVAL 1 HOUR GROUP BY time, type ORDER BY time ASC",
          "refId": "A",
          "format": 1
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
