      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
          "queryType": "sql",
          "rawSql": "SELECT city, count(*) as events FROM ads_analytics.ad_events WHERE event_time >= now() - INTERVAL 24 HOUR GROUP BY city ORDER BY events DESC LIMIT 15",
          "refId": "A",
          "format": 1
        }
      ],
      "options": {
        "orientation": "horizontal",
