  "panels": [
    {
      "id": 1,
      "title": "Ad Events - Tunisia Geo Map",
      "description": "Geographic distribution of ad interactions (views, clicks, hovers, creations)",
      "type": "geomap",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ads" },
          "queryType": "sql",
          "rawSql": "SELECT latitude, longitude, city, type, count(*) as event_count FROM ads_analytics.ad_events WHERE event_time >= now() - INTERVAL 24 HOUR GROUP BY latitude, longitude, city, type ORDER BY event_count DESC",
          "refId": "A",
          "format": 1
        }
      ],
      "options": {
        "view": {
          "id": "coords",
          "lat": 34.5,
          "lon": 9.5,
          "zoom": 6.5
        },
        "basemap": {
          "type": "default",
          "name": "OpenStreetMap"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Ad Events",
            "config": {
              "showLegend": true,
              "style": {
                "size": { "field": "event_count", "min": 5, "max": 30, "fixed": 10 },
                "color": { "field": "type", "fixed": "#FF6600" },
                "opacity": 0.8,
                "symbol": { "fixed": "img/icons/marker/circle.svg" }
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            },
            "tooltip": true
          }
        ],
        "tooltip": { "mode": "details" }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Events by City (Top 15)",
