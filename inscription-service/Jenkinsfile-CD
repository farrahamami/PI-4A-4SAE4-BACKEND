pipeline {
    agent any

    environment {
        DOCKER_IMAGE  = "marahmarah123/inscription-service"
        K8S_NAMESPACE = "default"
        APP_NAME      = "inscription-service"
        APP_PORT      = "8097"
        KUBECONFIG    = "/var/lib/jenkins/.kube/config"
    }

    stages {

        stage('Récupérer le tag CI') {
            steps {
                copyArtifacts(projectName: 'inscription-service-CI', selector: lastSuccessful(), filter: 'inscription-service-tag.txt')
                script {
                    env.DOCKER_TAG = readFile('inscription-service-tag.txt').trim()
                }
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${APP_NAME}
  namespace: ${K8S_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ${APP_NAME}
  template:
    metadata:
      labels:
        app: ${APP_NAME}
    spec:
      containers:
      - name: ${APP_NAME}
        image: ${DOCKER_IMAGE}:${env.DOCKER_TAG}
        ports:
        - containerPort: ${APP_PORT}
        imagePullPolicy: Always
        env:
        - name: DB_USERNAME
          valueFrom:
            secretKeyRef:
              name: inscription-mysql-secret
              key: mysql-root-password
        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: inscription-mysql-secret
              key: mysql-root-password
---
apiVersion: v1
kind: Service
metadata:
  name: ${APP_NAME}
  namespace: ${K8S_NAMESPACE}
spec:
  selector:
    app: ${APP_NAME}
  ports:
  - port: ${APP_PORT}
    targetPort: ${APP_PORT}
    nodePort: 30097
  type: NodePort
EOF
                    kubectl rollout status deployment/${APP_NAME} -n ${K8S_NAMESPACE} --timeout=300s
                """
            }
        }
    }

    post {
        success { echo 'inscription-service déployé ✅' }
        failure { echo 'Déploiement échoué ❌' }
    }
}