pipeline {
    agent any
    environment {
        DOCKER_IMAGE = "farrahamami/user-service"
        DOCKER_TAG   = "${BUILD_NUMBER}"
        SONAR_URL    = "http://localhost:9000"
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'devops/on-integrated6sur6/ads_cicd_k8s',
                    url: 'https://github.com/farrahamami/ESPRIT-PIDEV-4SAE4-2025-2026-Prolance-BACKEND.git'
            }
        }

        stage('Build & Package') {
            steps {
                dir('user-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Tests') {
            steps {
                dir('user-service') {
                    // FIX 1: Removed -DskipTests flag that was silently skipping all tests.
                    // FIX 2: Added -Dmaven.test.failure.ignore=true so a test failure doesn't
                    //         abort the stage before jacoco:report gets a chance to run.
                    sh '''./mvnw test jacoco:report \
                        -Dtest="!PidevApplicationTests" \
                        -Dsurefire.failIfNoSpecifiedTests=false \
                        -Dmaven.test.failure.ignore=true'''
                }
            }
            post {
                always {
                    // FIX 3: allowEmptyResults prevents the step from failing when no XML
                    //         report files exist (e.g. on a compilation error).
                    junit allowEmptyResults: true,
                          testResults: 'user-service/target/surefire-reports/*.xml'

                    // FIX 4: Paths are relative to workspace root, not the dir() block.
                    jacoco(
                        execPattern:   'user-service/target/jacoco.exec',
                        classPattern:  'user-service/target/classes',
                        sourcePattern: 'user-service/src/main/java',
                        reportPattern: 'user-service/target/site/jacoco/jacoco.xml'
                    )
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('user-service') {
                    withSonarQubeEnv('SonarQube') {
                        // FIX 5: Corrected broken markdown hyperlink that was pasted as code:
                        //         "-[Dsonar.host](http://Dsonar.host).url" → "-Dsonar.host.url"
                        sh '''./mvnw sonar:sonar \
                            -Dsonar.projectKey=user-service \
                            -Dsonar.host.url=${SONAR_URL} \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'''
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                dir('user-service') {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        sh 'docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} .'
                        sh 'docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest'
                        sh 'docker push ${DOCKER_IMAGE}:${DOCKER_TAG}'
                        sh 'docker push ${DOCKER_IMAGE}:latest'
                    }
                }
            }
        }

        stage('Save build info for CD') {
            steps {
                sh 'echo ${DOCKER_TAG} > user-service-tag.txt'
                archiveArtifacts artifacts: 'user-service-tag.txt'
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
        }
        success { echo '✅ CI user-service passed' }
        failure { echo '❌ CI user-service failed' }
    }
}